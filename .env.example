# ------------------------------------------------------------------------------
# Custom Environment Variables
# ------------------------------------------------------------------------------
# These environment variables are specific to a custom environment defined by the ENV_NAME variable.
# NOTE: Replace CUSTOM in the environment variables below to match the ENV_NAME variable. (e.g. STAGING, TRIAL, etc.)

# TENANT INFORMATION
# ------------------

# Tenant Name (e.g. example-company)
PYDPLUS_CUSTOM_TENANT_NAME=

# Base URL (e.g. https://example-company.access.securid.com)
# NOTE: This is a deprecated variable kept only for backwards compatibility. Use the Administration Base URL instead.
PYDPLUS_CUSTOM_BASE_URL=

